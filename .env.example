VITE_API_BASE_URL=http://127.0.0.1:3002

# Quando "true" (ou não definida), o frontend não acessa a API real: todas
# as chamadas são respondidas por um conjunto de dados mock em memória
# (@/lib/api/mock), permitindo rodar `npm run dev` sem o backend disponível
# localmente. Defina explicitamente "false" para usar a API real.
# Contas de demonstração (offline):
#   admin@forlife.app    / Admin@2026
#   personal@forlife.app / Personal@2026
#   aluno@forlife.app    / Aluno@2026
VITE_OFFLINE=true

# S3 – configurado no backend (Rails), não no frontend.
# O backend expõe POST /api/v1/uploads/presign e retorna { upload_url, public_url }.
# Variáveis necessárias no backend:
#   AWS_ACCESS_KEY_ID=
#   AWS_SECRET_ACCESS_KEY=
#   AWS_REGION=us-east-1
#   S3_BUCKET=forlife-videos
#   S3_PRESIGN_EXPIRY=600   # segundos de validade da URL assinada

# Web Push (VAPID) — deve ser idêntica ao VAPID_PUBLIC_KEY do backend.
VITE_VAPID_PUBLIC_KEY=

# Feature flags — escondem funcionalidades em desenvolvimento até serem
# liberadas de propósito (ver src/lib/feature-flags.ts). Ausente ou qualquer
# valor diferente de "true" = escondida (padrão); "true" = visível.
#   VITE_FEATURE_ATTENDANCE_CYCLES: histórico de ciclos de atendimento —
#   card "Histórico de ciclos" na Assiduidade do aluno, item de menu
#   "Assiduidade" (dos alunos) para admin/personal, e o campo "Treinos
#   contratados por ciclo" ao cadastrar/editar um aluno.
VITE_FEATURE_ATTENDANCE_CYCLES=false

#   VITE_FEATURE_AGENDA_CALENDAR: calendário de treinos dinâmico — item de
#   menu "Agenda" (admin/personal) e "Minha Agenda" (aluno), e as telas em si.
VITE_FEATURE_AGENDA_CALENDAR=false

#   VITE_FEATURE_CHAT: chat 1:1 entre personal e aluno — item de menu
#   "Mensagens" (admin/personal e aluno), e as telas em si.
VITE_FEATURE_CHAT=false

# Pact contract testing (consumer side) — usadas só por `npm run test:pact` e
# na publicação em CI, não em desenvolvimento normal. Veja docs/pact.md.
PACT_BROKER_BASE_URL=
PACT_BROKER_TOKEN=
PACT_CONSUMER_VERSION=
PACT_CONSUMER_BRANCH=
